# ─── Environnement STAGING ───────────────────────────────────────────────────
# Copier ce fichier en .env.staging et remplir les valeurs réelles.
# NE JAMAIS commiter .env.staging dans le repo.
#
# Ces variables sont à configurer dans Vercel :
#   Project Settings → Environment Variables → Environment : Preview
#   Restreindre à la branche "staging" pour isoler du reste des previews.

# Supabase — Projet "hanut-staging" (OBLIGATOIRE)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App — URL de l'environnement staging Vercel (OBLIGATOIRE)
# Récupérer l'URL après le premier déploiement de la branche staging sur Vercel.
# Format : https://hanut-staging.vercel.app ou URL de preview Vercel.
# Utilisée dans les emails Supabase (invitations, reset de mot de passe).
NEXT_PUBLIC_APP_URL=https://hanut-staging.vercel.app

# WhatsApp (même numéro que la prod si pas de numéro de test)
NEXT_PUBLIC_WHATSAPP_NUMBER=21600000000

# Cloudflare Turnstile — utiliser les clés du mode TEST Cloudflare pour le staging
# Clés de test universelles (pas besoin de créer un vrai site Turnstile) :
#   Site key  : 1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend — utiliser un expéditeur de test ou le même compte Resend avec un tag staging
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Hanut Staging <noreply@hanut.tn>

# OPS webhook — générer un secret différent de la prod
OPS_WEBHOOK_SECRET=staging-ops-secret-a-changer

# Sentry — désactivé en staging pour ne pas polluer les alertes prod (recommandé)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=hanut
SENTRY_PROJECT=javascript-nextjs

# Admin plateforme — emails autorisés à accéder à /admin
HANUT_ADMIN_EMAILS=admin@hanut.tn,vous@exemple.com
