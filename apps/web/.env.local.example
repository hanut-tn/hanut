# Supabase (OBLIGATOIRE)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare Turnstile (OBLIGATOIRE en production)
# Obtenir les clés sur : https://dash.cloudflare.com/turnstile
# Si absent en prod : toutes les commandes publiques et inscriptions seront bloquées
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here

# App
# URL canonique utilisée dans les emails Supabase (reset, invitation, confirmation).
# En production, utiliser le domaine stable, jamais une URL de preview Vercel.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WhatsApp (OBLIGATOIRE pour les CTAs d'upgrade)
NEXT_PUBLIC_WHATSAPP_NUMBER=21600000000

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=hanut
SENTRY_PROJECT=javascript-nextjs

# Admin plateforme — page /admin (liste d'e-mails Auth séparée par des virgules)
HANUT_ADMIN_EMAILS=admin@hanut.tn,vous@exemple.com

# Resend — envoi des emails OTP (vérification commande publique)
# Obtenir la clé sur : https://resend.com/api-keys
# Si absent : les codes OTP s'affichent uniquement en console (dev). Bloque l'envoi en production.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Expéditeur validé dans Resend (le domaine doit être vérifié)
RESEND_FROM_EMAIL=Hanut <noreply@hanut.tn>

# Variables réservées aux fonctionnalités à venir
# (SMS, paiement, APIs transporteurs)
# Décommenter quand les fonctionnalités seront développées
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# KONNECT_API_KEY=
# KONNECT_WALLET_ID=
# INTIGO_API_KEY=
# INTIGO_API_URL=https://api.intigo.tn
# NAVEX_API_KEY=
# NAVEX_API_URL=
