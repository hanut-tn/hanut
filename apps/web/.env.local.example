# Supabase (OBLIGATOIRE)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare Turnstile (OBLIGATOIRE en production)
# Obtenir les clés sur : https://dash.cloudflare.com/turnstile
# Si absent en prod : toutes les commandes publiques et inscriptions seront bloquées
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WhatsApp (OBLIGATOIRE pour les CTAs d'upgrade)
NEXT_PUBLIC_WHATSAPP_NUMBER=21600000000

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=hanut
SENTRY_PROJECT=javascript-nextjs

# Admin plateforme — page /admin (liste d'e-mails Auth séparée par des virgules)
HANUT_ADMIN_EMAILS=admin@hanut.tn,vous@exemple.com

# Variables réservées aux fonctionnalités à venir
# (SMS, paiement, APIs transporteurs)
# Décommenter quand les fonctionnalités seront développées
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# KONNECT_API_KEY=
# KONNECT_WALLET_ID=
